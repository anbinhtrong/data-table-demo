@{
    ViewData["Title"] = "DataTable Demo";
}

<div class="container mt-5">
    <h1>DataTable Demo</h1>
    <p class="text-muted">Interactive table with sorting, searching, and pagination</p>

    <div class="table-responsive">
        <table id="productTable" class="display">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th>Stock</th>
                    <th>Rating</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Apple</td>
                    <td>$10</td>
                    <td>Fruit</td>
                    <td>150</td>
                    <td>4.5</td>
                    <td><span class="badge bg-success">In Stock</span></td>
                </tr>
                <tr>
                    <td>Milk</td>
                    <td>$20</td>
                    <td>Dairy</td>
                    <td>80</td>
                    <td>4.8</td>
