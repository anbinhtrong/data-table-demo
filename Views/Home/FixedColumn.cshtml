@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/fixedcolumns/4.3.0/css/fixedColumns.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/4.3.0/js/dataTables.fixedColumns.min.js"></script>

    <style>
        #fixedColumnWrapper {
            overflow-x: auto;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        #fixedColumnTable {
            width: 100%;
            margin: 0;
        }

        #fixedColumnTable thead th {
            background-color: #007bff;
            color: white;
            font-weight: 600;
            padding: 12px;
            text-align: left;
            vertical-align: middle;
            white-space: nowrap;
        }

        #fixedColumnTable tbody tr:hover {
            background-color: #f5f5f5;
        }

        #fixedColumnTable tbody td {
            padding: 10px 12px;
            vertical-align: middle;
        }

        .dataTables_wrapper {
            margin: 0;
            padding: 0;
        }

        .dataTables_wrapper .dataTables_length {
            margin-bottom: 15px;
        }

        .dataTables_wrapper .dataTables_info {
            padding-top: 10px;
        }

        .dataTables_wrapper .dataTables_paginate {
            padding-top: 10px;
        }

        /* Ensure fixed columns display properly */
        div.dt-fixedcolumns-left,
        div.dt-fixedcolumns-right {
            z-index: 99;
        }

        div.dt-fixedcolumns-left {
            left: 0;
        }

        div.dt-fixedcolumns-right {
            right: 0;
        }
    </style>

    <script>
        $(document).ready(function () {
            var table = $('#fixedColumnTable').DataTable({
                scrollX: true,
                scrollCollapse: false,
                fixedColumns: {
                    left: 1,
                    right: 1
                },
                paging: true,
                pageLength: 10,
                lengthChange: true,
                searching: true,
                ordering: true,
                info: true,
                columnDefs: [
                    {
                        orderable: false,
                        targets: 9
                    }
                ]
            });

            // Reinitialize fixed columns after initialization
            new $.fn.dataTable.FixedColumns(table, {
                left: 1,
                right: 1
            });
        });
    </script>
}
