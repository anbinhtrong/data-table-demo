@{
    ViewData["Title"] = "State Saving Demo";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1>@ViewData["Title"]</h1>
            <p class="text-muted">
                Demo: DataTables State Saving - Remember sorting, pagination, search, and column filters
            </p>

            <div class="alert alert-info" role="alert">
                <h5 class="alert-heading">💡 How State Saving Works?</h5>
                <ul class="mb-0">
                    <li><strong>Automatic:</strong> DataTables automatically saves the table state to localStorage</li>
                    <li><strong>Persistent:</strong> State is restored when you revisit this page (even after closing browser)</li>
                    <li><strong>What's saved:</strong> Current page, page length, sort column, sort direction, search term, and column filters</li>
                    <li><strong>Clear state:</strong> Click the "Clear State" button below to reset everything</li>
                </ul>
            </div>

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><strong>Product Table with State Saving</strong></span>
                    <button id="clearStateBtn" class="btn btn-sm btn-warning">
                        <i class="bi bi-arrow-clockwise"></i> Clear Saved State
                    </button>
                </div>
                <div class="card-body">
                    <table id="stateSavingTable" class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Rating</th>
                                <th>Status</th>
                                <th>Date Added</th>
                                <th>Supplier</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header">
                    <strong>📊 State Information</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Current State:</strong></p>
                            <pre id="stateInfo" class="bg-light p-3 rounded" style="max-height: 300px; overflow-y: auto;">No state saved yet</pre>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Browser Storage Key:</strong></p>
                            <code class="d-block bg-light p-3 rounded mb-3">DataTables_stateSavingTable_/</code>
                            <p><strong>Storage Duration:</strong> <span class="badge bg-info">Permanent (until browser cache cleared)</span></p>
                            <p class="text-muted small">You can inspect this in Developer Tools → Application → Local Storage</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
            var table = $('#stateSavingTable').DataTable({
                ajax: {
                    url: '@Url.Action("GetProducts", "Home")',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'id' },
                    { data: 'name' },
                    { data: 'category' },
                    { data: 'price', render: function (data) { return '$' + parseFloat(data).toFixed(2); } },
                    { data: 'stock' },
                    { data: 'rating' },
                    { data: 'status' },
                    { data: 'dateAdded' },
                    { data: 'supplier' }
                ],
                processing: true,
                serverSide: false,
                paging: true,
                pageLength: 10,
                ordering: true,
                searching: true,
                info: true,
                lengthChange: true,
                dom: '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>' +
                     '<"row"<"col-sm-12"tr>>' +
                     '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
                // ===== STATE SAVING CONFIGURATION =====
                stateSave: true,
                stateDuration: 60 * 60 * 24, // Save for 24 hours (in seconds)
                // stateDuration: -1 would use sessionStorage (lost when browser closes)
                // stateDuration: 0 would use localStorage (permanent)
                // =====================================
                initComplete: function () {
                    var api = this.api();
                    var state = api.state.loaded(); // Get previously saved state

                    this.api().columns().every(function (colIndex) {
                        var column = this;
                        var header = $(column.header());
                        var columnTitle = header.text();

                        // Only create filter for Category (index 2) and Status (index 6)
                        if (colIndex === 2 || colIndex === 6) {
                            // Create dropdown filter structure
                            var dropdownId = 'filter-' + columnTitle.replace(/\s+/g, '-').toLowerCase();
                            var filterHtml = `
                                <div class="dropdown d-inline-block filter-container ms-2" id="filter-wrapper-${colIndex}">
                                    <i class="bi bi-caret-down-fill filter-icon" data-bs-toggle="dropdown" aria-expanded="false" title="Filter by ${columnTitle}"></i>
                                    <ul class="dropdown-menu shadow-lg" id="${dropdownId}">
                                        <li><a class="dropdown-item filter-option" href="#" data-value="">All ${columnTitle}</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    </ul>
                                </div>`;

                            var $filter = $(filterHtml);
                            header.html(columnTitle).append($filter);

                            // Get unique values and populate dropdown
                            column.data().unique().sort().each(function (d) {
                                $filter.find('.dropdown-menu').append(
                                    `<li><a class="dropdown-item filter-option" href="#" data-value="${d}">${d}</a></li>`
                                );
                            });

                            // ===== RESTORE SAVED STATE =====
                            // If there's a saved state, restore the filter value and UI
                            if (state && state.columns && state.columns[colIndex]) {
                                var colState = state.columns[colIndex];
                                if (colState.search && colState.search.search) {
                                    // Extract the value from regex (remove ^ and $)
                                    var savedValue = colState.search.search.replace(/^\^|\$$/g, '');

                                    // Highlight the saved option in dropdown
                                    $filter.find('.filter-option').each(function () {
                                        var optValue = $(this).data('value');
                                        if (optValue === savedValue) {
                                            $(this).addClass('active');
                                        }
                                    });

                                    // Add highlight to icon if filter is active
                                    if (savedValue !== "") {
                                        $filter.find('.filter-icon').addClass('text-warning');
                                    }
                                }
                            }
                            // ================================

                            // Handle dropdown option click
                            $filter.find('.filter-option').on('click', function (e) {
                                e.preventDefault();
                                var val = $(this).data('value');
                                var $icon = $(this).closest('.dropdown').find('.filter-icon');

                                // Remove active class from all options
                                $(this).closest('.dropdown-menu').find('.filter-option').removeClass('active');
                                $(this).addClass('active');

                                // Highlight icon if filter is active
                                if (val !== "") {
                                    $icon.addClass('text-warning');
                                } else {
                                    $icon.removeClass('text-warning');
                                }

                                // Apply filter with exact match regex
                                column.search(val ? '^' + $.fn.dataTable.util.escapeRegex(val) + '$' : '', true, false).draw();
                            });

                            // Prevent sort trigger when clicking filter
                            $filter.on('click', function (e) {
                                e.stopPropagation();
                            });
                        }
                    });

                    // Display current state information
                    updateStateInfo(api);
                }
            });

            // Listen to state change and update display
            table.on('stateLoaded.dt', function (e, settings, data) {
                updateStateInfo(table);
            });

            table.on('stateSaved.dt', function (e, settings, data) {
                updateStateInfo(table);
            });

            // Update state information display
            function updateStateInfo(api) {
                var state = api.state();
                if (state) {
                    var stateInfo = {
                        'Current Page': state.start / state.length + 1,
                        'Page Length': state.length,
                        'Search': state.search.search || '(none)',
                        'Sort Column': state.order.length > 0 ? 'Column ' + state.order[0][0] : '(none)',
                        'Sort Direction': state.order.length > 0 ? state.order[0][1].toUpperCase() : '(none)',
                        'Timestamp': new Date(state.time).toLocaleString()
                    };

                    $('#stateInfo').text(JSON.stringify(stateInfo, null, 2));
                }
            }

            // Clear state button
            $('#clearStateBtn').on('click', function () {
                if (confirm('Are you sure you want to clear all saved state? This cannot be undone.')) {
                    // Remove from localStorage
                    var stateKey = 'DataTables_stateSavingTable_/';
                    localStorage.removeItem(stateKey);

                    // Reload page
                    location.reload();
                }
            });
        });
    </script>

    <style>
        #stateSavingTable thead {
            background-color: #f8f9fa;
        }

        #stateSavingTable thead th {
            padding: 12px;
            border-bottom: 2px solid #dee2e6;
            vertical-align: middle;
            white-space: nowrap;
        }

        .filter-icon {
            font-size: 0.75rem;
            cursor: pointer;
            color: #999;
            transition: color 0.2s ease;
            user-select: none;
        }

        .filter-icon:hover {
            color: #495057;
        }

        .filter-icon.text-warning {
            color: #ffc107;
        }

        .filter-container {
            display: inline-block;
            position: relative;
        }

        #stateSavingTable .dropdown-menu {
            max-height: 300px;
            overflow-y: auto;
            min-width: 180px;
        }

        #stateSavingTable .dropdown-item {
            padding: 0.5rem 1rem;
            font-size: 0.875rem;
        }

        #stateSavingTable .dropdown-item:hover {
            background-color: #e9ecef;
        }

        #stateSavingTable .dropdown-item.active {
            background-color: #0d6efd;
            color: white;
        }

        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 15px;
        }

        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            margin-top: 15px;
        }

        pre {
            font-size: 0.875rem;
        }
    </style>
}
