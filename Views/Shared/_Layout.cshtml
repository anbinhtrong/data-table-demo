<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataTableSample</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DataTableSample.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-0">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">DataTableSample</a>
            </div>
        </nav>
    </header>
    <div class="main-content">
        <aside class="sidebar">
            <h5>📋 Demos</h5>
            <ul class="sidebar-nav">
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">
                        Home
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="DataTableDemo" class="@(ViewContext.RouteData.Values["action"].ToString() == "DataTableDemo" ? "active" : "")">
                        DataTable Demo
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="FixedColumn" class="@(ViewContext.RouteData.Values["action"].ToString() == "FixedColumn" ? "active" : "")">
                        Fixed Column
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="AjaxDataDemo" class="@(ViewContext.RouteData.Values["action"].ToString() == "AjaxDataDemo" ? "active" : "")">
                        Ajax Data Load
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="ServerSideLoadDemo" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServerSideLoadDemo" ? "active" : "")">
                        Server-Side Load
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="IndividualColumnSearching" class="@(ViewContext.RouteData.Values["action"].ToString() == "IndividualColumnSearching" ? "active" : "")">
                        Column Searching
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="StateSavingDemo" class="@(ViewContext.RouteData.Values["action"].ToString() == "StateSavingDemo" ? "active" : "")">
                        State Saving
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="@(ViewContext.RouteData.Values["action"].ToString() == "Privacy" ? "active" : "")">
                        Privacy
                    </a>
                </li>
            </ul>
        </aside>
        <div class="content-wrapper">
            <main role="main" class="pb-3 p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            &copy; 2026 - DataTableSample - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
